# Important Days App - Environment Variables Example
# Copy this file to .env and fill in your details

# Port for the server (default is 8083)
PORT=8083

# MongoDB Atlas Connection String
# Example: mongodb+srv://user:pass@cluster.mongodb.net/dbname
MONGODB_URI=your-mongodb-connection-string

# SMTP Email Configuration (Used for payment notifications)
# For Gmail, use an "App Password" (not your main password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
