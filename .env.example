# Important Days App - Environment Variables Example
# Copy this file to .env and fill in your details

# Port for the server (default is 8083)
PORT=8083

# MongoDB Atlas Connection String
# Example: mongodb+srv://user:pass@cluster.mongodb.net/dbname
MONGODB_URI=your-mongodb-connection-string

# SMTP Email Configuration (Used for payment notifications)
# For Gmail, use an "App Password" (not your main password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# AI Content Generation (Optional - Fallbacks to pollintations.ai or templates if missing)
# Google Gemini API (Recommended Free Option)
GEMINI_API_KEY=your_gemini_api_key
# OpenAI API
OPENAI_API_KEY=your_openai_key
# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_key

# Master Admin Credentials
ADMIN_ID=EMYRIS
ADMIN_PWD=NEW@1306
